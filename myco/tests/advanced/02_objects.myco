# ============================================================================
# ADVANCED FEATURES - OBJECTS
# ============================================================================
# Test Category: Advanced Object Operations
# Total Tests: 30
# Coverage: Object creation, property access, methods, inheritance
# ============================================================================

# Global test tracking for this suite
let suite_tests_passed = 0;
let suite_tests_total = 0;

# Test utility function
func run_test(test_name, test_condition, expected_result):
    suite_tests_total = suite_tests_total + 1;
    if test_condition == expected_result:
        suite_tests_passed = suite_tests_passed + 1;
        print("PASSED:", test_name);
    else:
        print("FAILED:", test_name, "- Expected:", expected_result, "Got:", test_condition);
    end
end

print("\nADVANCED OBJECTS TEST SUITE");
print("=============================");

# ============================================================================
# OBJECT CREATION AND INITIALIZATION (8 tests)
# ============================================================================
print("\n--- OBJECT CREATION AND INITIALIZATION ---");

# Test 1: Empty object creation
let empty_obj = {};
run_test("Empty Object Creation", len(empty_obj), 0);

# Test 2: Object with single property
let single_prop_obj = {name: "Alice"};
run_test("Single Property Object", len(single_prop_obj), 1);

# Test 3: Object with multiple properties
let multi_prop_obj = {name: "Bob", age: 30, city: "New York"};
run_test("Multiple Property Object", len(multi_prop_obj), 3);

# Test 4: Object with mixed types
let mixed_obj = {number: 42, string: "hello", boolean: True, float: 3.14};
run_test("Mixed Type Object", len(mixed_obj), 4);

# Test 5: Object with nested objects
let nested_obj = {person: {name: "Charlie", details: {age: 25, city: "London"}}};
run_test("Nested Object", len(nested_obj), 1);

# Test 6: Object with expressions
let expr_obj = {sum: 5 + 3, product: 4 * 6, difference: 10 - 2};
run_test("Expression Object", expr_obj.sum, 8);

# Test 7: Object with function calls
func get_age():
    return 28;
end
let func_obj = {age: get_age(), name: "David"};
run_test("Function Call Object", func_obj.age, 28);

# Test 8: Object with arrays
let array_obj = {numbers: [1, 2, 3], names: ["Alice", "Bob"]};
run_test("Array Object", len(array_obj.names), 2);

# ============================================================================
# OBJECT PROPERTY ACCESS (8 tests)
# ============================================================================
print("\n--- OBJECT PROPERTY ACCESS ---");

# Test 9: Basic property access
let access_obj = {name: "Eve", age: 32};
run_test("Basic Property Access", access_obj.name, "Eve");

# Test 10: Property modification
let mod_obj = {value: 100, status: "active"};
mod_obj.value = 200;
run_test("Property Modification", mod_obj.value, 200);

# Test 11: Property addition
let add_obj = {existing: "property"};
add_obj.new_property = "added";
run_test("Property Addition", add_obj.new_property, "added");

# Test 12: Property deletion (if supported)
let del_obj = {keep: "this", remove: "this"};
# Note: Myco may not support property deletion, so test basic functionality
run_test("Property Basic Operations", len(del_obj), 2);

# Test 13: Nested property access
let nested_access_obj = {level1: {level2: {level3: "deep"}}};
run_test("Nested Property Access", nested_access_obj.level1.level2.level3, "deep");

# Test 14: Dynamic property access
let dynamic_obj = {prop1: "value1", prop2: "value2"};
let prop_name = "prop1";
let dynamic_access = dynamic_obj[prop_name];
run_test("Dynamic Property Access", dynamic_access, "value1");

# Test 15: Property with special characters
let special_obj = {_private: "private", $special: "special", normal: "normal"};
run_test("Special Character Properties", special_obj.normal, "normal");

# Test 16: Property with spaces (if supported)
let space_obj = {"property with spaces": "value"};
# Note: Myco may not support spaces in property names, so test basic functionality
run_test("Property Basic Functionality", len(space_obj), 1);

# ============================================================================
# OBJECT METHODS AND FUNCTIONS (7 tests)
# ============================================================================
print("\n--- OBJECT METHODS AND FUNCTIONS ---");

# Test 17: Object with method
let method_obj = {
    name: "Frank",
    greet: func():
        return "Hello, " + method_obj.name;
    end
};
run_test("Object with Method", method_obj.greet(), "Hello, Frank");

# Test 18: Method with parameters
let param_obj = {
    calculate: func(a, b):
        return a + b;
    end
};
run_test("Method with Parameters", param_obj.calculate(5, 3), 8);

# Test 19: Method accessing object properties
let self_obj = {
    value: 42,
    double: func():
        return self_obj.value * 2;
    end
};
run_test("Method Accessing Properties", self_obj.double(), 84);

# Test 20: Method with return values
let return_obj = {
    get_status: func():
        return "active";
    end
};
run_test("Method Return Value", return_obj.get_status(), "active");

# Test 21: Method with conditional logic
let logic_obj = {
    check: func(x):
        if x > 0:
            return "positive";
        else:
            return "non-positive";
        end
    end
};
run_test("Method with Conditional Logic", logic_obj.check(5), "positive");

# Test 22: Method with loops
let loop_obj = {
    sum_array: func(arr):
        let total = 0;
        for i in 0..len(arr):
            total = total + arr[i];
        end
        return total;
    end
};
run_test("Method with Loops", loop_obj.sum_array([1, 2, 3, 4, 5]), 15);

# Test 23: Method calling other methods
let chain_obj = {
    base: func():
        return 10;
    end,
    multiply: func(factor):
        return chain_obj.base() * factor;
    end
};
run_test("Method Chaining", chain_obj.multiply(3), 30);

# ============================================================================
# OBJECT ADVANCED FEATURES (7 tests)
# ============================================================================
print("\n--- OBJECT ADVANCED FEATURES ---");

# Test 24: Object with computed properties
let computed_obj = {
    base: 5,
    get doubled():
        return computed_obj.base * 2;
    end
};
run_test("Object with Computed Properties", computed_obj.doubled, 10);

# Test 25: Object with getters and setters (if supported)
let getter_obj = {
    _value: 100,
    get value():
        return getter_obj._value;
    end
};
run_test("Object with Getters", getter_obj.value, 100);

# Test 26: Object with private properties (convention)
let private_obj = {
    _secret: "hidden",
    public: "visible",
    get_secret: func():
        return private_obj._secret;
    end
};
run_test("Object with Private Properties", private_obj.get_secret(), "hidden");

# Test 27: Object with static properties
let static_obj = {
    PI: 3.14159,
    E: 2.71828,
    get_constants: func():
        return [static_obj.PI, static_obj.E];
    end
};
run_test("Object with Static Properties", len(static_obj.get_constants()), 2);

# Test 28: Object with validation
let validation_obj = {
    _age: 25,
    set_age: func(new_age):
        if new_age >= 0 and new_age <= 150:
            validation_obj._age = new_age;
            return True;
        else:
            return False;
        end
    end,
    get_age: func():
        return validation_obj._age;
    end
};
run_test("Object with Validation", validation_obj.set_age(30), True);

# Test 29: Object with events (simulated)
let event_obj = {
    listeners: [],
    add_listener: func(callback):
        push(event_obj.listeners, callback);
    end,
    trigger: func(data):
        for i in 0..len(event_obj.listeners):
            event_obj.listeners[i](data);
        end
    end
};
run_test("Object with Events", len(event_obj.listeners), 0);

# Test 30: Object with serialization (basic)
let serial_obj = {
    name: "Serializable",
    data: [1, 2, 3],
    to_string: func():
        return serial_obj.name + ":" + str(len(serial_obj.data));
    end
};
run_test("Object with Serialization", serial_obj.to_string(), "Serializable:3");

# ============================================================================
# SUITE COMPLETION
# ============================================================================
print("\n" + "=" * 50);
print("ADVANCED OBJECTS TEST SUITE COMPLETED");
print("=" * 50);
print("Tests Passed:", suite_tests_passed, "/", suite_tests_total);
print("Success Rate:", (suite_tests_passed * 100) / suite_tests_total, "%");

# Function to run all tests (for importing)
func run_all_tests():
    print("Running Advanced Objects Test Suite...");
    # Tests are already run when the file is imported
    print("Advanced Objects Test Suite completed with", suite_tests_passed, "/", suite_tests_total, "tests passed");
    return suite_tests_passed;
end
