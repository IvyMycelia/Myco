# ============================================================================
# CORE LANGUAGE FEATURES - TEST EXECUTOR
# ============================================================================
# This function executes all core language feature tests
# ============================================================================

func execute_core_language_tests():
    print("\nEXECUTING CORE LANGUAGE FEATURES TEST SUITE");
    print("============================================");
    
    # Reset suite counters
    suite_tests_passed = 0;
    suite_tests_total = 0;
    
    # Execute Basic Operations Tests
    print("\n1. Testing Basic Operations...");
    execute_basic_operations_tests();
    
    # Execute Control Flow Tests
    print("\n2. Testing Control Flow...");
    execute_control_flow_tests();
    
    # Execute Data Types Tests
    print("\n3. Testing Data Types...");
    execute_data_types_tests();
    
    # Execute Functions Tests
    print("\n4. Testing Functions...");
    execute_functions_tests();
    
    # Execute Variables and Scope Tests
    print("\n5. Testing Variables and Scope...");
    execute_variables_scope_tests();
    
    print("\n" + "=" * 60);
    print("CORE LANGUAGE FEATURES TEST SUITE COMPLETED");
    print("=" * 60);
    print("Total Tests:", suite_tests_total);
    print("Tests Passed:", suite_tests_passed);
    print("Tests Failed:", suite_tests_total - suite_tests_passed);
    print("Success Rate:", (suite_tests_passed * 100) / suite_tests_total, "%");
    
    # Update global counters
    tests_passed = tests_passed + suite_tests_passed;
    tests_total = tests_total + suite_tests_total;
end

# Test execution functions for each category
func execute_basic_operations_tests():
    print("Basic Operations Tests - 25 tests");
    # Execute the actual test file
    use "tests/core/01_basic_operations.myco" as basic_tests;
    # Update counters from the executed tests
    suite_tests_passed = suite_tests_passed + basic_tests.suite_tests_passed;
    suite_tests_total = suite_tests_total + basic_tests.suite_tests_total;
end

