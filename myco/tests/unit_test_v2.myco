# Utility functions for test management
func start_test_suite(suite_name):
    current_suite = suite_name;
    suite_start_time = get_current_time();
    suite_start_memory = get_memory_usage();
    print("\n" + "=" * 60);
    print("EXECUTING:", suite_name);
    print("=" * 60);
end

# Helper function to run a test and update counters
func run_test(test_name, condition, suite_passed_var, suite_total_var):
    tests_total = tests_total + 1;
    suite_total_var = suite_total_var + 1;
    
    if condition:
        tests_passed = tests_passed + 1;
        suite_passed_var = suite_passed_var + 1;
        print("PASSED:", test_name);
        return 1;
    else:
        print("FAILED:", test_name);
        return 0;
    end
end

func end_test_suite(suite_name):
    let suite_end_time = get_current_time();
    let suite_end_memory = get_memory_usage();
    
    # Store results in a simpler way for now
    print("\n" + "-" * 40);
    print("SUITE COMPLETED:", suite_name);

    print("Execution Time: 0 ms");  # Placeholder
    print("Memory Usage: 0 bytes");  # Placeholder
    print("-" * 40);
end

